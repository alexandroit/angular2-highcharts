{
  "name": "angular2-highcharts",
  "version": "4.0.0",
  "description": "Highcharts components for Angular 4 applications",
  "scripts": {
    "watch": "tsc -w",
    "build": "rm -rf dist && ngc",
    "test": "karma start karma.conf.js",
    "build:docs": "npm run build && rm -rf docs && mkdir -p docs && cp docs-src/index.html docs/index.html && webpack --config docs-src/webpack.config.js",
    "serve:docs": "http-server docs -p 8080 -c-1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexandroit/angular2-highcharts.git"
  },
  "keywords": [
    "angular",
    "angular4",
    "charts",
    "highcharts",
    "wrapper",
    "library",
    "highstock",
    "highmaps"
  ],
  "author": "Eugene Gluhotorenko",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alexandroit/angular2-highcharts/issues"
  },
  "homepage": "https://github.com/alexandroit/angular2-highcharts#readme",
  "peerDependencies": {
    "@angular/core": "^4.4.7",
    "highcharts": "^5.0.7"
  },
  "devDependencies": {
    "@angular/common": "^4.4.7",
    "@angular/compiler": "^4.4.7",
    "@angular/compiler-cli": "^4.4.7",
    "@angular/core": "^4.4.7",
    "@angular/http": "^4.4.7",
    "@angular/platform-browser": "^4.4.7",
    "@angular/platform-browser-dynamic": "^4.4.7",
    "@angular/platform-server": "^4.4.7",
    "core-js": "^2.4.1",
    "jasmine-core": "~2.5.2",
    "karma": "^1.4.1",
    "karma-chrome-launcher": "^2.0.0",
    "karma-jasmine": "^1.1.0",
    "http-server": "^14.1.1",
    "reflect-metadata": "^0.1.9",
    "rxjs": "^5.5.12",
    "systemjs": "0.19.39",
    "typescript": "~2.4.2",
    "ts-loader": "^3.5.0",
    "webpack": "^3.12.0",
    "zone.js": "^0.8.29",
    "@types/highcharts": "4.2.47",
    "@types/jasmine": "2.5.42",
    "highcharts": "^5.0.7"
  },
  "dependencies": {}
}

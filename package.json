{
  "name": "@revivejs/angular2-highcharts",
  "version": "11.0.0",
  "description": "Angular wrapper components for Highcharts, Highstock, Highmaps, zAxis, and colorAxis integrations",
  "main": "dist/bundles/revivejs-angular2-highcharts.umd.js",
  "module": "dist/fesm2015/revivejs-angular2-highcharts.js",
  "es2015": "dist/fesm2015/revivejs-angular2-highcharts.js",
  "esm2015": "dist/esm2015/revivejs-angular2-highcharts.js",
  "fesm2015": "dist/fesm2015/revivejs-angular2-highcharts.js",
  "typings": "dist/revivejs-angular2-highcharts.d.ts",
  "metadata": "dist/revivejs-angular2-highcharts.metadata.json",
  "sideEffects": false,
  "scripts": {
    "watch": "tsc -w",
    "build": "ng-packagr -p ng-package.json",
    "test": "karma start karma.conf.js",
    "docs:install:angular-4": "cd docs-src/angular-4 && npm install --ignore-scripts",
    "build:docs:angular-4": "cd docs-src/angular-4 && npm run build",
    "docs:install:angular-5": "cd docs-src/angular-5 && npm install --ignore-scripts",
    "build:docs:angular-5": "cd docs-src/angular-5 && npm run build",
    "docs:install:angular-6": "cd docs-src/angular-6 && npm install --ignore-scripts",
    "build:docs:angular-6": "cd docs-src/angular-6 && npm run build",
    "docs:install:angular-7": "cd docs-src/angular-7 && npm install --ignore-scripts",
    "build:docs:angular-7": "cd docs-src/angular-7 && npm run build",
    "docs:install:angular-8": "cd docs-src/angular-8 && npm install --ignore-scripts",
    "build:docs:angular-8": "cd docs-src/angular-8 && npm run build",
    "docs:install:angular-9": "cd docs-src/angular-9 && npm install --ignore-scripts",
    "build:docs:angular-9": "cd docs-src/angular-9 && npm run build",
    "docs:install:angular-10": "cd docs-src/angular-10 && npm install --ignore-scripts",
    "build:docs:angular-10": "cd docs-src/angular-10 && npm run build",
    "docs:install:angular-11": "cd docs-src/angular-11 && npm install --ignore-scripts",
    "build:docs:angular-11": "cd docs-src/angular-11 && npm run build",
    "build:docs": "npm run build:docs:angular-11",
    "serve:docs": "http-server docs -p 8080 -c-1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexandroit/angular2-highcharts.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "angular",
    "angular4",
    "angular5",
    "angular6",
    "angular7",
    "angular8",
    "angular9",
    "angular10",
    "angular11",
    "angular-library",
    "typescript",
    "charts",
    "highcharts",
    "highcharts-angular",
    "chart-wrapper",
    "ui-component",
    "wrapper",
    "library",
    "highstock",
    "highmaps",
    "coloraxis",
    "zaxis",
    "revived",
    "maintained",
    "modernized",
    "sankey",
    "streamgraph",
    "sunburst",
    "variwide",
    "parallel-coordinates",
    "variable-radius-pie",
    "vector-plot",
    "windbarb",
    "xrange",
    "bullet-chart",
    "annotations",
    "boost",
    "tilemap",
    "accessibility",
    "organization-chart",
    "dependency-wheel",
    "item-chart",
    "venn-diagram",
    "timeline-chart",
    "packedbubble",
    "arc-diagram",
    "pictorial-chart",
    "marker-clusters",
    "data-sorting",
    "bundled-types",
    "ivy",
    "3d-area",
    "single-touch-zoom",
    "hlc",
    "cumulative-sum",
    "node-offsets",
    "annotations-crop",
    "trusted-types"
  ],
  "author": "Alexandro Paixao Marques",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alexandroit/angular2-highcharts/issues"
  },
  "homepage": "https://alexandroit.github.io/angular2-highcharts/",
  "peerDependencies": {
    "@angular/core": ">=4.0.0 <12.0.0",
    "highcharts": ">=5.0.0"
  },
  "devDependencies": {
    "@angular/common": "^11.2.14",
    "@angular/compiler": "^11.2.14",
    "@angular/compiler-cli": "^11.2.14",
    "@angular/core": "^11.2.14",
    "@angular/platform-browser": "^11.2.14",
    "@angular/platform-browser-dynamic": "^11.2.14",
    "@angular/platform-server": "^11.2.14",
    "core-js": "^2.4.1",
    "jasmine-core": "~2.5.2",
    "karma": "^1.4.1",
    "karma-chrome-launcher": "^2.0.0",
    "karma-jasmine": "^1.1.0",
    "http-server": "^14.1.1",
    "ng-packagr": "^11.2.4",
    "reflect-metadata": "^0.1.9",
    "rxjs": "^6.6.7",
    "sass": "1.22.9",
    "tsickle": "0.46.3",
    "typescript": "~4.1.6",
    "zone.js": "~0.11.8",
    "@types/jasmine": "2.5.42",
    "@types/node": "12.12.54",
    "highcharts": "^9.3.3"
  },
  "dependencies": {
    "tslib": "^2.0.0"
  }
}

{
  "name": "@revivejs/angular2-highcharts",
  "version": "5.0.0",
  "description": "Angular wrapper components for Highcharts, Highstock, Highmaps, zAxis, and colorAxis integrations",
  "scripts": {
    "watch": "tsc -w",
    "build": "rm -rf dist && ngc",
    "test": "karma start karma.conf.js",
    "docs:install:angular-4": "cd docs-src/angular-4 && npm install --ignore-scripts",
    "build:docs:angular-4": "cd docs-src/angular-4 && npm run build",
    "docs:install:angular-5": "cd docs-src/angular-5 && npm install --ignore-scripts",
    "build:docs:angular-5": "cd docs-src/angular-5 && npm run build",
    "build:docs": "npm run build:docs:angular-5",
    "serve:docs": "http-server docs -p 8080 -c-1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alexandroit/angular2-highcharts.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "angular",
    "angular4",
    "angular5",
    "angular-library",
    "typescript",
    "charts",
    "highcharts",
    "highcharts-angular",
    "chart-wrapper",
    "ui-component",
    "wrapper",
    "library",
    "highstock",
    "highmaps",
    "coloraxis",
    "zaxis",
    "revived",
    "maintained",
    "modernized",
    "gantt",
    "xrange",
    "bullet-chart",
    "windbarb",
    "streamgraph",
    "accessibility"
  ],
  "author": "Alexandro Paixao Marques",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alexandroit/angular2-highcharts/issues"
  },
  "homepage": "https://alexandroit.github.io/angular2-highcharts/",
  "peerDependencies": {
    "@angular/core": ">=4.0.0 <6.0.0",
    "highcharts": ">=5.0.0"
  },
  "devDependencies": {
    "@angular/common": "^5.2.11",
    "@angular/compiler": "^5.2.11",
    "@angular/compiler-cli": "^5.2.11",
    "@angular/core": "^5.2.11",
    "@angular/http": "^5.2.11",
    "@angular/platform-browser": "^5.2.11",
    "@angular/platform-browser-dynamic": "^5.2.11",
    "@angular/platform-server": "^5.2.11",
    "core-js": "^2.4.1",
    "jasmine-core": "~2.5.2",
    "karma": "^1.4.1",
    "karma-chrome-launcher": "^2.0.0",
    "karma-jasmine": "^1.1.0",
    "http-server": "^14.1.1",
    "reflect-metadata": "^0.1.9",
    "rxjs": "^5.5.12",
    "typescript": "~2.6.2",
    "zone.js": "^0.8.29",
    "@types/highcharts": "5.0.44",
    "@types/jasmine": "2.5.42",
    "highcharts": "^6.0.0"
  },
  "dependencies": {}
}
